# Local development — copy to `.env` in this directory.
# `src/index.ts` imports `dotenv/config` so variables are loaded before `loadConfig()`.
#
# Infra:
#   docker compose -f deployment/docker-compose.yml up -d redis
#
# `simulate` avoids SSI FastConnect credentials; use `live` when you have access.

MARKET_FEED_MODE=simulate
# MARKET_FEED_MODE=live

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

FASTCONNECT_WS_URL=wss://fc-datahub.ssi.com.vn/v2.0
FASTCONNECT_CHANNELS=X,R,MI,F,B
# FASTCONNECT_SUBSCRIBE_PAYLOAD=

MARKET_FEED_PORT=8100
# PORT=8100
HEARTBEAT_INTERVAL_MS=1000
FASTCONNECT_RECONNECT_MS=2000

# Simulation (MARKET_FEED_MODE=simulate)
SIM_SYMBOLS=SSI,VND,VCB
SIM_TICK_INTERVAL_MS=500
SIM_PRICE_STEP=0.05
# SIM_BASE_PRICES=SSI:24.5,VND:12.3
