# Local development — copy to `.env` in this directory.
# `src/index.ts` loads `.env` via `dotenv.config()` before `loadConfig()`.
#
# Infra:
#   docker compose -f deployment/docker-compose.yml up -d redis
#
# `simulate` avoids SSI FastConnect credentials; use `live` when you have access.

MARKET_FEED_MODE=simulate
# MARKET_FEED_MODE=live

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Live: hub base (v2.0); `/signalr` is appended automatically if missing.
FASTCONNECT_WS_URL=wss://fc-datahub.ssi.com.vn/v2.0
# REST base for AccessToken (defaults to SSI FC Data HTTPS origin).
FASTCONNECT_API_URL=https://fc-data.ssi.com.vn
# Shorthand channel codes are mapped to SSI SwitchChannels specs (e.g. X -> X-QUOTE:ALL).
FASTCONNECT_CHANNELS=X,R,MI,F,B
# Optional: override with full comma-separated SwitchChannels values.
# FASTCONNECT_SIGNALR_CHANNELS=X-QUOTE:ALL,R-QUOTE:ALL
# FASTCONNECT_SUBSCRIBE_PAYLOAD=

# Token + HTTP tuning (live)
# FASTCONNECT_TOKEN_REFRESH_LEAD_MS=300000
# FASTCONNECT_HTTP_TIMEOUT_MS=15000
# FASTCONNECT_TOKEN_DEFAULT_TTL_SEC=28800

MARKET_FEED_PORT=8100
# PORT=8100
HEARTBEAT_INTERVAL_MS=1000
FASTCONNECT_RECONNECT_MS=2000

# Simulation (MARKET_FEED_MODE=simulate)
SIM_SYMBOLS=SSI,VND,VCB
SIM_TICK_INTERVAL_MS=500
SIM_PRICE_STEP=0.05
# SIM_BASE_PRICES=SSI:24.5,VND:12.3
# SIM_VOLUME_BASE=5000
# SIM_VOLUME_STEP=250

# SSI config (required when MARKET_FEED_MODE=live)
CONSUMER_ID=
CONSUMER_SECRET=